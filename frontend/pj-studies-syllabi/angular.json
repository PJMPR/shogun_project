{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "pj-studies-syllabi": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/pj-studies-syllabi",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "es-module-shims.js",
                "input": "node_modules/es-module-shims/dist/",
                "output": "/"
              },
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1MB",
                  "maximumError": "5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4202
          },
          "configurations": {
            "production": {
              "buildTarget": "pj-studies-syllabi:build:production"
            },
            "development": {
              "buildTarget": "pj-studies-syllabi:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "serve-mfe": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "pj-studies-syllabi:serve:development",
            "federationConfig": "federation.config.js",
            "verbose": false
          },
          "configurations": {
            "production": {
              "target": "pj-studies-syllabi:build:production"
            }
          }
        },
        "build-mfe": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "pj-studies-syllabi:build:production",
            "federationConfig": "federation.config.js",
            "verbose": false
          },
          "configurations": {
            "production": {
              "target": "pj-studies-syllabi:build:production"
            }
          }
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
