{     "sylabus": {         "uczelnia": "Polsko-Japonska Akademia Technik Komputerowych Filia w Gdansku",         "jednostka": "Filia w Gdansku",         "kierunek": "INFORMATYKA",         "profil": "praktyczny",         "tryb_studiow": "stacjonarny",         "wersja_z_dnia": "08.03.2026",         "nazwa_przedmiotu": "Statystyczna analiza danych",         "kod_przedmiotu": "SAD",         "rok_studiow": 2,         "semestr_studiow": 3,         "obligatoryjny": false,         "forma_i_liczba_godzin_zajec": {             "wyklady": 30,             "cwiczenia_lektorat_seminarium": 30,             "laboratorium_projekt": null         },         "odpowiedzialny_za_przedmiot": "Dr Monika Wrzosek",         "ects": 4,         "godziny": {             "z_udzialem_prowadzacego_h": 60,             "praca_wlasna_studenta_h": 60,             "calkowita_liczba_godzin_h": 120,             "praca_wlasna_studenta": "Samodzielna analiza zbiorów danych statystycznych; ćwiczenia z narzędzi statystycznych (R, Python); przygotowanie do kolokwiów laboratoryjnych i egzaminu pisemnego."         },         "metody_dydaktyczne": {             "wyklad": [                 "wykład z prezentacją multimedialną"             ],             "cwiczenia_laboratorium": [                 "rozwiązywanie zadań",                 "warsztaty"             ]         },         "zaliczenie": {             "Wykład": {                 "sposob": "Egzamin"             }         },         "kryteria_oceny": {             "wyklad": [                 "egzamin pisemny"             ],             "cwiczenia_laboratorium": [                 "kolokwium"             ]         },         "przedmioty_wprowadzajace": [             {                 "nazwa": "Analiza matematyczna,",                 "wymagania": "Elementy rachunku różniczkowego i całkowego"             },             {                 "nazwa": "Podstawy Programowania",                 "wymagania": ""             }         ],         "cel_dydaktyczny": "Celem przedmiotu jest zapoznanie studentów ze sposobami prezentacji i analizy danych oraz narzędziami modelowania probabilistycznego; przedstawienie metod statystyki matematycznej i wnioskowania statystycznego oraz nabycieprzez studentów praktycznych umiejętności wykorzystania oprogramowania do statystycznej analizy danych.",         "cel_dydaktyczny_eng": "The aim of the course is to familiarize students with methods of data presentation and analysis as well as probabilistic modeling tools; to present methods of mathematical statistics and statistical inference; and to equip students with practical skills in using software for statistical data analysis.",         "literatura": {             "podstawowa": {                 "pozycje": [                     "Michael Baron, Probability and Statistics for Computer Scientists, 3rd edition. American University Chapman & Hall/CRC, 2019."                 ]             },             "uzupelniajaca": {                 "pozycje": [                     "Koronacki J., Mielniczuk J., Statystyka dla studentów kierunków technicznych i przyrodniczych, WNT, 2018.",                     "Plucińska A., Pluciński E., Probabilistyka, PWN, 2017."                 ]             }         },         "efekty_ksztalcenia": {             "wiedza": [                 "Student zna i rozumie zaawansowane zagadnienia probabilistyki i statystyki: rozkłady prawdopodobieństwa, procesy stochastyczne, łańcuchy Markowa, teorię kolejek i metody Monte Carlo w kontekście zastosowań informatycznych. [K_W12]",                 "Student zna i rozumie metody statystycznej analizy danych: estymację parametryczną i nieparametryczną, testowanie hipotez, regresję liniową i podstawy analizy bayesowskiej. [K_W12]"             ],             "umiejetnosci": [                 "Student potrafi zastosować aparat matematyczny statystyki do analizy danych informatycznych, implementować modele probabilistyczne i interpretować wyniki analiz statystycznych. [K_U07]",                 "Student potrafi posługiwać się narzędziami analityki danych (Python: NumPy, SciPy, pandas, matplotlib) do eksploracji i wizualizacji danych oraz budowy podstawowych modeli predykcyjnych. [K_U07]"             ],             "kompetencje_spoleczne": [                 "Student jest gotów do zastosowania metod statystycznych w analizie danych na rzecz rozwiązywania problemów naukowych i inżynierskich. [K_K01]",                 "Student jest gotów do samodzielnego uczenia się przez całe życie, aktualizując wiedzę z zakresu statystyki i analizy danych. [K_K03]"             ]         },         "tresci_programowe": [             {                 "nr_zajec": 1,                 "wyklad": "Prawdopodobieństwo klasyczne i warunkowe. Niezależność zdarzeń. Prawdopodobieństwo całkowite. Wzór Bayesa. Niezawodność systemu.",                 "cwiczenia": ""             },             {                 "nr_zajec": 2,                 "wyklad": "Zmienne losowe dyskretne, dystrybuanta, wartość oczekiwana i wariancja. Rozkłady dwumianowy, ujemny dwumianowy i Poissona.",                 "cwiczenia": ""             },             {                 "nr_zajec": 3,                 "wyklad": "Zmienne losowe ciągłe, gęstość, dystrybuanta, wartość oczekiwana i wariancja. Rozkłady jednostajny, geometryczny, wykładniczy, gamma i normalny. Centralne twierdzenie graniczne.",                 "cwiczenia": ""             },             {                 "nr_zajec": 4,                 "wyklad": "Zmienne losowe dwuwymiarowa. Rozkłady brzegowe. Niezależność zmiennych losowych.",                 "cwiczenia": ""             },             {                 "nr_zajec": 5,                 "wyklad": "Zastosowania metody Monte Carlo.",                 "cwiczenia": ""             },             {                 "nr_zajec": 6,                 "wyklad": "Elementy procesów stochastycznych. Łańcuchy Markowa.",                 "cwiczenia": ""             },             {                 "nr_zajec": 7,                 "wyklad": "Elementy teorii kolejek.",                 "cwiczenia": ""             },             {                 "nr_zajec": 8,                 "wyklad": "Statystyka opisowa.Miary położenia, rozproszenia, asymetrii, koncentracji.",                 "cwiczenia": ""             },             {                 "nr_zajec": 9,                 "wyklad": "Estymacja punktowa i przedziałowa parametrów rozkładów.",                 "cwiczenia": ""             },             {                 "nr_zajec": 10,                 "wyklad": "Testowanie hipotez statystycznych.",                 "cwiczenia": ""             },             {                 "nr_zajec": 11,                 "wyklad": "Model regresji liniowej.",                 "cwiczenia": ""             }         ],         "informacje_dodatkowe": "",         "rynek_pracy": {             "dziedzina_gospodarki": "",             "zawody": "",             "prace_dyplomowe": []         },         "wymagania_laboratorium": {             "pc_params": [],             "software": [],             "wyposazenie_dodatkowe": []         }     } }