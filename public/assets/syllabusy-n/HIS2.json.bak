        "tresci_programowe": [
            {
                "nr_zajec": 1,
                "wyklad": "Życie codzienne – czas zegarowy, czynności wykonywane w różnych porach dnia. Odmiana czasowników regularnych w czasie teraźniejszym.",
                "cwiczenia": ""
            },
            {
                "nr_zajec": 2,
                "wyklad": "Życie codzienne – czynności dnia codziennego. Odmiana czasowników nieregularnych (e→ie, o→ue, u→ue, e→i) w czasie teraźniejszym.",
                "cwiczenia": ""
            },
            {
                "nr_zajec": 3,
                "wyklad": "Pogoda – zjawiska atmosferyczne, nazwy miesięcy, kierunki geograficzne, pory roku. Użycie rodzajnika określonego przy porach dnia i datach.",
                "cwiczenia": ""
            },
            {
                "nr_zajec": 4,
                "wyklad": "Czas wolny – nazwy zainteresowań i upodobań. Czasowniki gustar i encantar w czasie teraźniejszym. Przysłówki tampoco i también.",
                "cwiczenia": ""
            },
            {
                "nr_zajec": 5,
                "wyklad": "Jedzenie – artykuły spożywcze i rodzaje opakowań, piramida żywieniowa. Przysłówki i wyrażenia czasu. Posiłki w Kolumbii i Hiszpanii.",
                "cwiczenia": ""
            },
            {
                "nr_zajec": 6,
                "wyklad": "Jedzenie – nazwy potraw i posiłków, składanie i przyjmowanie zamówień w lokalu gastronomicznym. Powtórzenie wiadomości.",
